# Backend selector — comment/uncomment ONE:
#GENAI_BACKEND=gateway
GENAI_BACKEND=vertex
#GENAI_BACKEND=gemini

# --- NeuralTrust Gateway (used when GENAI_BACKEND=gateway) ---
NEURALTRUST_GATEWAY_URL=https://gateway.neuraltrust.ai/vertex
NEURALTRUST_API_KEY=your-neuraltrust-api-key

# --- Gemini Developer API (used when GENAI_BACKEND=gemini) ---
GEMINI_API_KEY=

# --- Vertex AI (used when GENAI_BACKEND=vertex or gateway) ---
# Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud region
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI endpoint — two supported formats:
#
#   Base URL only (project/location/model read from env vars above):
#     VERTEX_AI_ENDPOINT=https://us-central1-aiplatform.googleapis.com
#
#   Full URL (project, location, model, api_version all parsed from it):
#     VERTEX_AI_ENDPOINT=https://us-central1-aiplatform.googleapis.com/v1beta1/projects/my-proj/locations/us-central1/publishers/google/models/gemini-2.0-flash:generateContent
#
VERTEX_AI_ENDPOINT=

# API version — only used when VERTEX_AI_ENDPOINT is a base URL
# Options: v1beta1 (default, preview features) | v1 (stable)
VERTEX_AI_API_VERSION=v1beta1

# Enable Vertex AI mode (used by the SDK when GENAI_BACKEND=vertex or gateway)
GOOGLE_GENAI_USE_VERTEXAI=true

# Model to use — only needed when GENAI_BACKEND=gemini or VERTEX_AI_ENDPOINT is a base URL
MODEL_ID=gemini-2.5-flash
